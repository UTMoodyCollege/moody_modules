<section class="moody-image-gallery" id="{{ gallery_id }}" style="--moody-image-gallery-gap: {{ gutter }}rem;">
  {% if headline %}
    <header class="moody-image-gallery__header">
      <h2 class="moody-image-gallery__headline">{{ headline }}</h2>
    </header>
  {% endif %}

  <div class="moody-image-gallery__grid">
    {% for group in items|batch(3, null) %}
      <div class="moody-image-gallery__group">
        <div class="moody-image-gallery__group-top">
          {% if group[0] %}
            <button
              class="moody-image-gallery__tile moody-image-gallery__tile--primary"
              type="button"
              data-gallery-trigger
              data-gallery-index="{{ group[0].index }}"
              aria-label="Open gallery image {{ group[0].index + 1 }} of {{ items|length }}{% if group[0].caption %}: {{ group[0].caption }}{% elseif group[0].alt %}: {{ group[0].alt }}{% endif %}"
            >
              <div class="moody-image-gallery__image-wrap" style="--moody-image-gallery-focus: {{ group[0].focus_position }};">
                {{ {
                  '#theme': 'image',
                  '#uri': group[0].thumbnail_uri,
                  '#alt': group[0].alt,
                  '#attributes': {
                    class: ['moody-image-gallery__image'],
                    loading: 'lazy',
                  }
                } }}
              </div>
            </button>
          {% endif %}
          {% if group[1] %}
            <button
              class="moody-image-gallery__tile moody-image-gallery__tile--secondary"
              type="button"
              data-gallery-trigger
              data-gallery-index="{{ group[1].index }}"
              aria-label="Open gallery image {{ group[1].index + 1 }} of {{ items|length }}{% if group[1].caption %}: {{ group[1].caption }}{% elseif group[1].alt %}: {{ group[1].alt }}{% endif %}"
            >
              <div class="moody-image-gallery__image-wrap" style="--moody-image-gallery-focus: {{ group[1].focus_position }};">
                {{ {
                  '#theme': 'image',
                  '#uri': group[1].thumbnail_uri,
                  '#alt': group[1].alt,
                  '#attributes': {
                    class: ['moody-image-gallery__image'],
                    loading: 'lazy',
                  }
                } }}
              </div>
            </button>
          {% endif %}
        </div>

        {% if group[2] %}
          <button
            class="moody-image-gallery__tile moody-image-gallery__tile--full"
            type="button"
            data-gallery-trigger
            data-gallery-index="{{ group[2].index }}"
            aria-label="Open gallery image {{ group[2].index + 1 }} of {{ items|length }}{% if group[2].caption %}: {{ group[2].caption }}{% elseif group[2].alt %}: {{ group[2].alt }}{% endif %}"
          >
            <div class="moody-image-gallery__image-wrap" style="--moody-image-gallery-focus: {{ group[2].focus_position }};">
              {{ {
                '#theme': 'image',
                '#uri': group[2].thumbnail_uri,
                '#alt': group[2].alt,
                '#attributes': {
                  class: ['moody-image-gallery__image'],
                  loading: 'lazy',
                }
              } }}
            </div>
          </button>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  <div
    class="moody-image-gallery__lightbox"
    data-gallery-dialog
    hidden
  >
    <div class="moody-image-gallery__backdrop" data-gallery-close tabindex="-1"></div>
    <div
      class="moody-image-gallery__dialog"
      role="dialog"
      aria-modal="true"
      aria-label="Image gallery"
      aria-describedby="{{ gallery_id }}-caption"
      tabindex="-1"
    >
      <button class="moody-image-gallery__close" type="button" data-gallery-close aria-label="Close gallery">
        <span aria-hidden="true">&times;</span>
      </button>

      <div class="moody-image-gallery__stage">
        <button class="moody-image-gallery__nav moody-image-gallery__nav--prev" type="button" data-gallery-prev aria-label="Previous image">
          <span aria-hidden="true">&#8592;</span>
        </button>

        <figure class="moody-image-gallery__figure">
          <img class="moody-image-gallery__modal-image" data-gallery-image src="" alt="">
          <figcaption class="moody-image-gallery__caption" id="{{ gallery_id }}-caption" data-gallery-caption></figcaption>
        </figure>

        <button class="moody-image-gallery__nav moody-image-gallery__nav--next" type="button" data-gallery-next aria-label="Next image">
          <span aria-hidden="true">&#8594;</span>
        </button>
      </div>

      <div class="moody-image-gallery__counter" data-gallery-counter></div>
    </div>

    <script type="application/json" data-gallery-items>
      [
        {% for item in items %}
          {
            "src": {{ file_url(item.uri)|json_encode|raw }},
            "alt": {{ item.alt|json_encode|raw }},
            "caption": {{ item.caption|json_encode|raw }}
          }{% if not loop.last %},{% endif %}
        {% endfor %}
      ]
    </script>
  </div>
</section>
