<?php

use Drupal\Core\Form\FormStateInterface;
use Drupal\layout_builder\Form\ConfigureBlockFormBase;

/**
 * Implements hook_form_BASE_FORM_ID_alter().
 */
function moody_block_publishing_form_layout_builder_configure_block_alter(array &$form, FormStateInterface $form_state): void {
  $form_object = $form_state->getFormObject();
  if (!$form_object instanceof ConfigureBlockFormBase) {
    return;
  }

  $component = $form_object->getCurrentComponent();
  $is_unpublished = (bool) $component->get('moody_block_publishing_unpublished');

  $form['moody_block_publishing'] = [
    '#type' => 'details',
    '#title' => t('Publishing'),
    '#weight' => 90,
    '#open' => $is_unpublished,
  ];
  $form['moody_block_publishing']['unpublished'] = [
    '#type' => 'checkbox',
    '#title' => t('Unpublish this block'),
    '#description' => t('Hide this block from typical site visitors while keeping it in Layout Builder for staging and preview.'),
    '#default_value' => $is_unpublished,
  ];

  $form['actions']['submit']['#submit'][] = 'moody_block_publishing_layout_builder_block_submit';
}

/**
 * Submit handler for Layout Builder block publishing settings.
 */
function moody_block_publishing_layout_builder_block_submit(array &$form, FormStateInterface $form_state): void {
  $form_object = $form_state->getFormObject();
  if (!$form_object instanceof ConfigureBlockFormBase) {
    return;
  }

  $component = $form_object->getCurrentComponent();
  $component->set('moody_block_publishing_unpublished', (bool) $form_state->getValue(['moody_block_publishing', 'unpublished']));
  \Drupal::service('layout_builder.tempstore_repository')->set($form_object->getSectionStorage());
}
