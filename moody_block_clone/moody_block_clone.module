<?php

declare(strict_types=1);

use Drupal\Component\Serialization\Json;
use Drupal\Core\Url;
use Drupal\layout_builder\SectionStorageInterface;

/**
 * Implements hook_page_attachments_alter().
 */
function moody_block_clone_page_attachments_alter(array &$attachments): void {
  $route_match = \Drupal::routeMatch();
  if ($route_match->getRouteName() !== 'layout_builder.choose_block') {
    return;
  }

  $section_storage = $route_match->getParameter('section_storage');
  $delta = $route_match->getParameter('delta');
  $region = $route_match->getParameter('region');

  if (!$section_storage instanceof SectionStorageInterface || $delta === NULL || $region === NULL) {
    return;
  }

  $attachments['#attached']['library'][] = 'moody_block_clone/chooser';
  $attachments['#attached']['drupalSettings']['moodyBlockClone'] = [
    'chooseUrl' => Url::fromRoute('moody_block_clone.choose', [
      'section_storage_type' => $section_storage->getStorageType(),
      'section_storage' => $section_storage->getStorageId(),
      'delta' => $delta,
      'region' => $region,
    ])->toString(),
  ];
}

/**
 * Implements hook_preprocess().
 */
function moody_block_clone_preprocess(array &$variables, $hook, array $info): void {
  $element = NULL;
  if (!empty($info['variables'])) {
    $keys = array_keys($info['variables']);
    $key = $keys[0] ?? NULL;
    if ($key && isset($variables[$key])) {
      $element = $variables[$key];
    }
  }
  elseif (!empty($info['render element']) && isset($variables[$info['render element']])) {
    $element = $variables[$info['render element']];
  }

  if (!is_array($element) || empty($element['#contextual_links']['layout_builder_block'])) {
    return;
  }

  $metadata = $element['#contextual_links']['layout_builder_block']['metadata'] ?? [];
  $operations = array_filter(explode(':', (string) ($metadata['operations'] ?? '')));
  if (!in_array('convert_reusable', $operations, TRUE)) {
    $operations[] = 'convert_reusable';
  }
  $element['#contextual_links']['layout_builder_block']['metadata']['operations'] = implode(':', $operations);

  if (!empty($info['variables']) && !empty($key)) {
    $variables[$key] = $element;
  }
  elseif (!empty($info['render element'])) {
    $variables[$info['render element']] = $element;
  }
}

/**
 * Implements hook_contextual_links_alter().
 */
function moody_block_clone_contextual_links_alter(array &$links, $group, array $route_parameters): void {
  if ($group !== 'layout_builder_block' || !moody_block_clone_route_exists('moody_block_clone.convert_reusable')) {
    return;
  }

  $links['moody_block_clone_convert_reusable'] = [
    'route_name' => 'moody_block_clone.convert_reusable',
    'route_parameters' => $route_parameters,
    'localized_options' => [],
    'title' => t('Convert to Reusable Block'),
    'weight' => 15,
  ];
}

/**
 * Implements hook_link_alter().
 */
function moody_block_clone_link_alter(array &$variables): void {
  if (empty($variables['url']) || !$variables['url'] instanceof Url || !$variables['url']->isRouted()) {
    return;
  }

  $route_name = $variables['url']->getRouteName();
  if (!in_array($route_name, ['moody_block_clone.convert_reusable', 'moody_block_clone.choose'], TRUE)) {
    return;
  }

  $attributes = moody_block_clone_dialog_attributes();
  if (!isset($variables['options']['attributes'])) {
    $variables['options']['attributes'] = [];
  }

  foreach ($attributes as $key => $value) {
    if ($key === 'class') {
      $variables['options']['attributes']['class'] = array_values(array_unique(array_merge($variables['options']['attributes']['class'] ?? [], $value)));
      continue;
    }
    $variables['options']['attributes'][$key] = $value;
  }
}

/**
 * Implements hook_layout_builder_browser_alter().
 */
function moody_block_clone_layout_builder_browser_alter(array &$build, array $context): void {
  $section_storage = $context['section_storage'] ?? NULL;
  $delta = $context['delta'] ?? NULL;
  $region = $context['region'] ?? NULL;

  if (!$section_storage instanceof SectionStorageInterface || $delta === NULL || $region === NULL) {
    return;
  }

  $attributes = moody_block_clone_dialog_attributes();
  $build['#attached']['library'][] = 'moody_block_clone/chooser';
  $build['moody_block_clone_action'] = [
    '#type' => 'details',
    '#weight' => -20,
    '#title' => t('Clone block from other page'),
    '#open' => FALSE,
    '#attributes' => [
      'class' => ['moody-block-clone__browser-action'],
    ],
    'description' => [
      '#type' => 'container',
      '#attributes' => [
        'class' => ['moody-block-clone__browser-description'],
      ],
      'text' => [
        '#markup' => t('Browse published pages, preview their inline blocks, and duplicate one into this section.'),
      ],
    ],
    'link' => [
      '#type' => 'link',
      '#title' => t('Open clone browser'),
      '#url' => Url::fromRoute('moody_block_clone.choose', [
        'section_storage_type' => $section_storage->getStorageType(),
        'section_storage' => $section_storage->getStorageId(),
        'delta' => $delta,
        'region' => $region,
      ]),
      '#attributes' => $attributes,
    ],
  ];
}

/**
 * Builds dialog attributes that match the active browser presentation.
 */
function moody_block_clone_dialog_attributes(): array {
  if (\Drupal::config('layout_builder_browser.settings')->get('use_modal')) {
    return [
      'class' => ['button', 'button--primary', 'use-ajax', 'moody-block-clone__browser-link'],
      'data-dialog-type' => 'dialog',
      'data-dialog-options' => Json::encode([
        'width' => '80%',
        'height' => 'auto',
        'target' => 'layout-builder-modal',
        'autoResize' => TRUE,
        'modal' => TRUE,
      ]),
    ];
  }

  return [
    'class' => ['button', 'button--primary', 'use-ajax', 'moody-block-clone__browser-link'],
    'data-dialog-type' => 'dialog',
    'data-dialog-renderer' => 'off_canvas',
  ];
}

/**
 * Checks whether a route exists before adding optional UI links.
 */
function moody_block_clone_route_exists(string $route_name): bool {
  try {
    \Drupal::service('router.route_provider')->getRouteByName($route_name);
    return TRUE;
  }
  catch (\Exception $exception) {
    return FALSE;
  }
}
