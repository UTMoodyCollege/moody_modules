/**
 * Adds Moody text size style definitions to Flex HTML CKEditor 5.
 */
function _moody_fleet_deploy_enable_moody_text_styles_on_flex_html() {
  $config_factory = \Drupal::configFactory();
  $editor = $config_factory->getEditable('editor.editor.flex_html');

  if ($editor->isNew() || $editor->get('editor') !== 'ckeditor5') {
    return;
  }

  $styles = $editor->get('settings.plugins.ckeditor5_style.styles') ?? [];
  $definitions = [
    [
      'label' => 'UT Size: Small',
      'element' => '<span class="moody-text-size-sm">',
    ],
    [
      'label' => 'UT Size: Large',
      'element' => '<span class="moody-text-size-lg">',
    ],
    [
      'label' => 'UT Size: XL',
      'element' => '<span class="moody-text-size-xl">',
    ],
    [
      'label' => 'UT Size: 2XL',
      'element' => '<span class="moody-text-size-2xl">',
    ],
  ];

  $existing_elements = [];
  foreach ($styles as $style) {
    if (!empty($style['element']) && is_string($style['element'])) {
      $existing_elements[] = $style['element'];
    }
  }

  $updated = FALSE;
  foreach ($definitions as $definition) {
    if (!in_array($definition['element'], $existing_elements, TRUE)) {
      $styles[] = $definition;
      $updated = TRUE;
    }
  }

  if ($updated) {
    $editor->set('settings.plugins.ckeditor5_style.styles', $styles)->save();
  }
}

/**
 * Ensures the Moody Layout Builder Browser feature module is enabled.
 */
function _moody_fleet_deploy_enable_moody_layout_builder_browser() {
  if (\Drupal::moduleHandler()->moduleExists('moody_layout_builder_browser')) {
    return;
  }

  \Drupal::service('module_installer')->install(['moody_layout_builder_browser'], TRUE);
}

/**
 * Ensures the Moody Media Image Helper module is enabled.
 */
function _moody_fleet_deploy_enable_moody_media_image_helper() {
  if (\Drupal::moduleHandler()->moduleExists('moody_media_image_helper')) {
    return;
  }

  \Drupal::service('module_installer')->install(['moody_media_image_helper'], TRUE);
}

/**
 * Ensures the Moody Block Publishing module is enabled.
 */
function _moody_fleet_deploy_enable_moody_block_publishing() {
  if (\Drupal::moduleHandler()->moduleExists('moody_block_publishing')) {
    return;
  }

  \Drupal::service('module_installer')->install(['moody_block_publishing'], TRUE);
}

/**
 * Ensures the Speedway theme is installed when its code is available.
 */
function _moody_fleet_deploy_install_speedway_theme() {
  if (\Drupal::service('theme_handler')->themeExists('speedway')) {
    return;
  }

  $available_themes = \Drupal::service('extension.list.theme')->reset()->getList();
  if (!isset($available_themes['speedway'])) {
    return;
  }

  \Drupal::service('theme_installer')->install(['speedway'], TRUE);
}

/**
 * Ensures the Moody required links block exists in footer_right.
 */
function _moody_fleet_deploy_place_moody_required_links_block() {
  if (!\Drupal::moduleHandler()->moduleExists('utexas_block_required_links')) {
    return;
  }

  if (!\Drupal::service('theme_handler')->themeExists('moody')) {
    return;
  }

  $block = \Drupal\block\Entity\Block::load('moody_required_links_block');
  $uuid = '35f5a6a4-6bc8-466f-b478-799aa1d59d4e';
  if ($block && $block->uuid() !== $uuid) {
    $block->delete();
    $block = NULL;
  }

  $settings = [
    'id' => 'required_links_block',
    'label' => 'Required Links Block',
    'label_display' => '0',
    'provider' => 'utexas_block_required_links',
  ];

  if (!$block) {
    $block = \Drupal\block\Entity\Block::create([
      'uuid' => $uuid,
      'id' => 'moody_required_links_block',
      'theme' => 'moody',
      'region' => 'footer_right',
      'weight' => 0,
      'status' => TRUE,
      'plugin' => 'required_links_block',
      'settings' => $settings,
      'visibility' => [],
    ]);
  }
  else {
    $block
      ->set('theme', 'moody')
      ->set('region', 'footer_right')
      ->set('weight', 0)
      ->set('status', TRUE)
      ->set('plugin', 'required_links_block')
      ->set('settings', $settings);
  }

  $block->save();
}

/**
 * Imports and reverts config from the Moody Layout Builder Browser feature.
 */
function _moody_fleet_deploy_revert_moody_layout_builder_browser() {
  if (!\Drupal::moduleHandler()->moduleExists('moody_layout_builder_browser')) {
    return;
  }

  if (!\Drupal::moduleHandler()->moduleExists('features')) {
    return;
  }

  \Drupal::service('features.manager')->import(['moody_layout_builder_browser']);
}
