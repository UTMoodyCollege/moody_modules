/**
 * @file
 * Install and update hooks for Moody Fleet Deploy.
 */

/**
 * Implements hook_install().
 */
function moody_fleet_deploy_install() {
  _moody_fleet_deploy_enable_nice_letter_on_flex_html();
  _moody_fleet_deploy_enable_nice_letter_toolbar_on_flex_html();
  _moody_fleet_deploy_enable_readable_text_toolbar_on_flex_html();
  _moody_fleet_deploy_enable_image_caption_toolbar_on_flex_html();
  _moody_fleet_deploy_enable_moody_text_styles_on_flex_html();
  _moody_fleet_deploy_enable_moody_block_publishing();
  _moody_fleet_deploy_enable_moody_media_image_helper();
  _moody_fleet_deploy_enable_moody_layout_builder_browser();
  _moody_fleet_deploy_revert_moody_layout_builder_browser();
  _moody_fleet_deploy_install_speedway_theme();
  _moody_fleet_deploy_place_moody_required_links_block();
}

