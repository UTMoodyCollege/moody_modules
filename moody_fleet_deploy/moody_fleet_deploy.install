  _moody_fleet_deploy_enable_nice_letter_on_flex_html();
  _moody_fleet_deploy_enable_nice_letter_toolbar_on_flex_html();
  _moody_fleet_deploy_enable_readable_text_toolbar_on_flex_html();
  _moody_fleet_deploy_enable_image_caption_toolbar_on_flex_html();
  _moody_fleet_deploy_enable_moody_text_styles_on_flex_html();
}

