<?php

/**
 * @file
 * Contains moody_flex_grid.module.
 */

use Drupal\block\BlockForm;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function moody_flex_grid_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    // Main module help for the moody_flex_grid module.
    case 'help.page.moody_flex_grid':
      $output = '';
      $output .= '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('Themed and accessible grid creator') . '</p>';
      return $output;

    default:
  }
}

/**
 * Implements hook_theme().
 */
function moody_flex_grid_theme() {
  return [
    'moody_flex_grid' => [
      'variables' => [
        'headline' => NULL,
        'style' => NULL,
        'flex_grid_items' => NULL,
      ],
      'template' => 'moody-flex-grid-standard',
    ],
    'moody_flex_grid_special' => [
      'variables' => [
        'headline' => NULL,
        'style' => NULL,
        'flex_grid_items' => NULL,
      ],
      'template' => 'moody-flex-grid-special',
    ],
    'moody_flex_grid_promo' => [
      'variables' => [
        'headline' => NULL,
        'style' => NULL,
        'flex_grid_items' => NULL,
      ],
      'template' => 'moody-flex-grid-promo',
    ],
    'moody_flex_grid_circular' => [
      'variables' => [
        'headline' => NULL,
        'style' => NULL,
        'flex_grid_items' => NULL,
      ],
      'template' => 'moody-flex-grid-circular',
    ],
    'moody_flex_grid_rectangular' => [
      'variables' => [
        'headline' => NULL,
        'style' => NULL,
        'flex_grid_items' => NULL,
      ],
      'template' => 'moody-flex-grid-rectangular',
    ],
    // Define a 'flip' variant that has the same as the others.
    'moody_flex_grid_flip' => [
      'variables' => [
        'headline' => NULL,
        'style' => NULL,
        'flex_grid_items' => NULL,
      ],
      'template' => 'moody-flex-grid-flip',
    ],
    'moody_flex_grid_card' => [
      'variables' => [
        'headline' => NULL,
        'style' => NULL,
        'flex_grid_items' => NULL,
      ],
      'template' => 'moody-flex-grid-card',
    ],
  ];
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function moody_flex_grid_form_layout_builder_update_block_alter(&$form, FormStateInterface $form_state, $form_id) {
  _moody_flex_grid_simplify_layout_form($form);
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function moody_flex_grid_form_layout_builder_add_block_alter(&$form, FormStateInterface $form_state, $form_id) {
  _moody_flex_grid_simplify_layout_form($form);
}

/**
 * Implements hook_form_FORM_ID_alter().
 *
 * Add logic to the place block form.
 */
function moody_flex_grid_form_block_form_alter(&$form, &$form_state, $form_id) {
  $bundle = FALSE;
  $form_object = $form_state->getFormObject();
  if ($form_object instanceof BlockForm) {
    /** @var \Drupal\block\Entity\Block $entity */
    $entity = $form_object->getEntity();
    $uuid = $entity->getPlugin()->getDerivativeId();
    if (isset($uuid)) {
      $block_content = \Drupal::service('entity.repository')->loadEntityByUuid('block_content', $uuid);
      if (!empty($block_content) && method_exists($block_content, 'bundle')) {
        $bundle = $block_content->bundle();
        if ($bundle === 'moody_flex_grid' && isset($form['settings']['view_mode']['#options'])) {
          $form['settings']['view_mode']['#options'] = _moody_flex_grid_view_mode_labels($form['settings']['view_mode']['#options']);
          _moody_flex_grid_attach_preview_assets($form);
        }
      }
    }
  }
}

/**
 * Helper function for Layout Builder block alter handling.
 */
function _moody_flex_grid_simplify_layout_form(array &$form) {
  $is_flex_grid = FALSE;

  if (isset($form['settings']['block_form'])) {
    $bundle = $form['settings']['block_form']['#block']->bundle();
    if ($bundle === 'moody_flex_grid') {
      $is_flex_grid = TRUE;
    }
  }

  if (isset($form['settings']['provider']) && ($form['settings']['provider']['#value'] ?? NULL) === 'block_content') {
    $options = array_keys($form['settings']['view_mode']['#options'] ?? []);
    if (in_array('flex_grid_card_style', $options, TRUE)) {
      $is_flex_grid = TRUE;
    }
  }

  if ($is_flex_grid && isset($form['settings']['view_mode']['#options'])) {
    $form['settings']['view_mode']['#options'] = _moody_flex_grid_view_mode_labels($form['settings']['view_mode']['#options']);
    _moody_flex_grid_attach_preview_assets($form);
  }
}

/**
 * Returns friendly labels for Flex Grid view mode options.
 */
function _moody_flex_grid_view_mode_labels(array $options) {
  $labels = [
    'default' => t('Default: Standard grid layout'),
    'flex_grid_circular_style' => t('Circular Style: Circular image-forward cards'),
    'flex_grid_promo_style' => t('Promo Style: Promotional tiles with stronger media presence'),
    'flex_grid_rectangular_style' => t('Rectangular Style: Rectangular media cards'),
    'flex_grid_flip_style' => t('Flip Style: Interactive flip-card treatment'),
    'flex_grid_card_style' => t('Card Style: Card-based content blocks'),
  ];

  return array_intersect_key($labels, $options);
}

/**
 * Attaches the Flex Grid preview enhancement assets to the config form.
 */
function _moody_flex_grid_attach_preview_assets(array &$form) {
  $module_path = \Drupal::service('extension.list.module')->getPath('moody_flex_grid');
  $form['#attached']['library'][] = 'moody_flex_grid/flex_grid_view_mode_preview';
  $form['#attached']['drupalSettings']['moodyFlexGrid']['modulePath'] = base_path() . $module_path;
}
